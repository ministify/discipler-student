    <script>    const DB={name:'DisciplerCMS',version:5,db:null,async connect(){if(this.db)return this.db;return new Promise(res=>{const req=indexedDB.open(this.name,this.version);req.onupgradeneeded=e=>{const db=e.target.result;if(!db.objectStoreNames.contains('studies'))db.createObjectStore('studies',{keyPath:'id'});if(!db.objectStoreNames.contains('dashboard'))db.createObjectStore('dashboard',{keyPath:'id'});};req.onsuccess=e=>{this.db=e.target.result;res(this.db)}})},async getMeta(){await this.connect();return new Promise(res=>{const items=[];this.db.transaction('studies','readonly').objectStore('studies').openCursor().onsuccess=e=>{const c=e.target.result;if(c){items.push(c.value);c.continue()}else res(items)}})},async savePlan(p){await this.connect();this.db.transaction('studies','readwrite').objectStore('studies').put(p)},async deletePlan(id){await this.connect();this.db.transaction('studies','readwrite').objectStore('studies').delete(id)},async getDashboard(){await this.connect();return new Promise(res=>{const req=this.db.transaction('dashboard','readonly').objectStore('dashboard').getAll();req.onsuccess=()=>res(req.result.reduce((acc,i)=>{acc[i.id]=i.data;return acc},{}))})},async saveDashboard(d){await this.connect();const tx=this.db.transaction('dashboard','readwrite');Object.keys(d).forEach(k=>tx.objectStore('dashboard').put({id:k,data:d[k]}))},async bulkImport(d){await this.connect();const tx=this.db.transaction(['studies','dashboard'],'readwrite');(d.studies||[]).forEach(s=>tx.objectStore('studies').put(s));(d.dashboard||[]).forEach(x=>tx.objectStore('dashboard').put(x))},async exportAll(){await this.connect();const studies=await this.getMeta();const dashboard=await this.getDashboard();return{studies,dashboard:Object.keys(dashboard).map(k=>({id:k,data:dashboard[k]}))}}};
    let currentEditingId = null;    let collapsedCategories = {};
    async function init(){        await DB.connect();                const goHome = () => switchView('dashboard-view');        document.getElementById('nav-home').addEventListener('click', goHome);        document.getElementById('back-from-preview').addEventListener('click', goHome);                document.getElementById('nav-menu').addEventListener('click', () => toggleSidebar(true));        document.getElementById('close-sidebar').addEventListener('click', () => toggleSidebar(false));        document.getElementById('sidebar-backdrop').addEventListener('click', () => toggleSidebar(false));
        document.getElementById('edit-dash-btn').addEventListener('click', () => { document.getElementById('dash-editor-overlay').classList.remove('hidden'); });        document.getElementById('close-dash-editor').addEventListener('click', saveDash);
        document.getElementById('sidebar-add-btn').addEventListener('click', openNewEditor);        document.getElementById('edit-fab').addEventListener('click', openExistingEditor);        document.getElementById('save-done-btn').addEventListener('click', saveLesson);        document.getElementById('cancel-edit').addEventListener('click', () => switchView('dashboard-view'));
        document.getElementById('btn-export').addEventListener('click', exportData);        document.getElementById('btn-import').addEventListener('click', () => document.getElementById('file-import').click());        document.getElementById('file-import').addEventListener('change', importBackup);        document.getElementById('search-input').addEventListener('input', (e) => filterLessons(e.target.value));
        document.getElementById('import-doc-input').addEventListener('change', importTextFile);
        const editor = document.getElementById('editor-content');        editor.addEventListener('input', updateStats);
        await renderDash();        await refreshSidebar();    }
    async function renderDash(){        const d = await DB.getDashboard();        const empty = '<div class="text-slate-400 italic text-xs">Nothing here yet.</div>';                document.getElementById('dash-announcements').innerHTML = (d.announcements || 'No announcements.').split('\n').map(l=>`<div class="bg-slate-50 p-3 rounded-lg border border-slate-100 mb-2 text-sm text-slate-700">${l}</div>`).join('');        document.getElementById('dash-schedule').innerHTML = (d.schedule || 'No schedule set.').replace(/\n/g, '<br>') || empty;        document.getElementById('dash-assignments').innerHTML = (d.assignments || 'No tasks.').split('\n').map(l=>`<div class="flex items-start gap-2"><div class="mt-1.5 w-1.5 h-1.5 rounded-full bg-indigo-400 shrink-0"></div><span>${l}</span></div>`).join('') || empty;        document.getElementById('dash-pointers').innerHTML = (d.pointers || 'No pointers.').split('\n').map(l=>`<div class="flex items-start gap-2"><div class="mt-1.5 w-1.5 h-1.5 rounded-full bg-emerald-400 shrink-0"></div><span>${l}</span></div>`).join('') || empty;                const resourceLines = (d.resources || '').split('\n').filter(l => l.trim() !== '');        if (resourceLines.length > 0) {            document.getElementById('dash-resources').innerHTML = resourceLines.map(l => {                let url = l.trim();                if (!url.startsWith('http') && !url.includes(' ')) url = 'https://' + url;                return `<a href="${url}" target="_blank" class="block text-sky-600 hover:text-sky-800 hover:underline truncate flex items-center gap-2 transition-colors"><svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>${l}</a>`;            }).join('');        } else { document.getElementById('dash-resources').innerHTML = empty; }
        document.getElementById('edit-dash-announcements').value = d.announcements || '';        document.getElementById('edit-dash-schedule').value = d.schedule || '';        document.getElementById('edit-dash-assignments').value = d.assignments || '';        document.getElementById('edit-dash-pointers').value = d.pointers || '';        document.getElementById('edit-dash-resources').value = d.resources || '';    }
    async function saveDash(){        const data = {            announcements: document.getElementById('edit-dash-announcements').value,            schedule: document.getElementById('edit-dash-schedule').value,            assignments: document.getElementById('edit-dash-assignments').value,            pointers: document.getElementById('edit-dash-pointers').value,            resources: document.getElementById('edit-dash-resources').value        };        await DB.saveDashboard(data);        renderDash();        document.getElementById('dash-editor-overlay').classList.add('hidden');    }
    function openNewEditor() {        if(window.innerWidth < 1024) toggleSidebar(false);        currentEditingId = Date.now().toString();        document.getElementById('edit-title').value = '';        document.getElementById('edit-category').value = '';        document.getElementById('editor-content').innerHTML = '';        updateStats();        switchView('editor-view');    }
    async function openExistingEditor(idToOpen) {        let plan;        if(typeof idToOpen === 'string') {            const all = await DB.getMeta();            plan = all.find(p => p.id === idToOpen);        } else {             const all = await DB.getMeta();             plan = all.find(p => p.id === currentEditingId);        }        if(!plan) return;        if(window.innerWidth < 1024) toggleSidebar(false);
        currentEditingId = plan.id;        document.getElementById('edit-title').value = plan.title;        document.getElementById('edit-category').value = plan.category || '';                let content = '';        if (Array.isArray(plan.content)) content = plan.content.join('');        else if (typeof plan.content === 'string') content = plan.content;                document.getElementById('editor-content').innerHTML = content;        updateStats();        switchView('editor-view');    }
    function execCmd(command, value = null) {        document.execCommand(command, false, value);    }
    async function importTextFile(e) {        const file = e.target.files[0];        if(!file) return;                const reader = new FileReader();        reader.onload = function(e) {            const text = e.target.result;            const html = text.replace(/\n/g, '<br>');            document.execCommand('insertHTML', false, html);        };        reader.readAsText(file);    }
    function updateStats() {        const text = document.getElementById('editor-content').innerText || '';        const words = text.trim().split(/\s+/).filter(w => w.length > 0).length;        document.getElementById('word-count').textContent = `${words} words`;        document.getElementById('read-time').textContent = `${Math.ceil(words / 200)} min read`;    }

    async function saveLesson(e) {
        if(e) e.preventDefault();
        const titleInput = document.getElementById('edit-title');
        
        if(!titleInput.value.trim()) {
            alert('Please enter a title');
            return;
        }

        switchView('dashboard-view');
        if(window.innerWidth < 1024) toggleSidebar(false);

        try {
            const title = titleInput.value;
            const category = document.getElementById('edit-category').value.trim();
            const contentHtml = document.getElementById('editor-content').innerHTML;

            const all = await DB.getMeta();
            const existing = all.find(p => p.id === currentEditingId);
            const isPinned = existing ? (existing.pinned || false) : false;

            const plan = {
                id: currentEditingId,
                title: title,
                category: category || 'Uncategorized',
                content: [contentHtml],
                updated: new Date().toISOString(),
                pinned: isPinned
            };

            await DB.savePlan(plan);
            await refreshSidebar();
        } catch(err) {
            console.error(err);
        }
    }

    async function duplicateLesson(id, e) {        e.stopPropagation();        const all = await DB.getMeta();        const original = all.find(p => p.id === id);        if(!original) return;
        const newId = Date.now().toString();        const copy = {            ...original,            id: newId,            title: original.title + ' (Copy)',            updated: new Date().toISOString(),            pinned: false         };        await DB.savePlan(copy);        await refreshSidebar();    }
    async function togglePin(id, e) {        e.stopPropagation();        const all = await DB.getMeta();        const plan = all.find(p => p.id === id);        if(plan) {            plan.pinned = !plan.pinned;            await DB.savePlan(plan);            await refreshSidebar();        }    }
    function toggleCategory(cat) {
        collapsedCategories[cat] = collapsedCategories[cat] === false ? true : false;
        DB.getMeta().then(plans => { renderLessonList(plans); });
    }
    async function deleteLessonById(id, e) {        e.stopPropagation();        if(confirm('Are you sure you want to delete this lesson?')) {            await DB.deletePlan(id);            await refreshSidebar();            if(currentEditingId === id) switchView('dashboard-view');        }    }
    async function refreshSidebar(){        const plans = await DB.getMeta();        renderLessonList(plans);        const categories = [...new Set(plans.map(p => p.category || 'Uncategorized'))];        document.getElementById('category-list').innerHTML = categories.map(c => `<option value="${c}">`).join('');    }
    function renderLessonList(plans) {        const list = document.getElementById('plans-list');        list.innerHTML = '';        if(plans.length === 0) {            list.innerHTML = '<div class="text-center text-slate-400 text-xs py-8">No lessons yet.<br>Click "New Lesson" below.</div>';            return;        }
        const pinned = plans.filter(p => p.pinned);        if(pinned.length > 0) {            const header = document.createElement('div');            header.className = "text-[10px] font-bold text-sky-600 uppercase tracking-widest mt-2 mb-1 px-2 flex items-center gap-1";            header.innerHTML = `<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"/></svg> PINNED`;            list.appendChild(header);            pinned.forEach(p => list.appendChild(createLessonItem(p)));            const separator = document.createElement('div');            separator.className = "border-b border-slate-100 my-2";            list.appendChild(separator);        }
        const unpinned = plans.filter(p => !p.pinned);        const catMap = {};        unpinned.forEach(p => {            const c = p.category || 'Uncategorized';            if(!catMap[c]) catMap[c] = [];            catMap[c].push(p);        });
        const sortedCats = Object.keys(catMap).sort();
        sortedCats.forEach(cat => {
            const items = catMap[cat];
            items.sort((a,b) => (b.updated || 0) > (a.updated || 0) ? 1 : -1);

            const headerDiv = document.createElement('div');
            headerDiv.className = "flex items-center justify-between cursor-pointer hover:bg-slate-50 rounded px-2 py-1 mt-2 group select-none";
            headerDiv.onclick = () => toggleCategory(cat);

            const isCollapsed = collapsedCategories[cat] !== false; 
            const chevronClass = isCollapsed ? 'chevron collapsed' : 'chevron';
            const count = items.length;

            headerDiv.innerHTML = `
                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">${cat} <span class="text-slate-300 ml-1">(${count})</span></span>
                <svg class="w-3 h-3 text-slate-400 ${chevronClass}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            `;
            list.appendChild(headerDiv);

            if(!isCollapsed) {
                const itemContainer = document.createElement('div');
                itemContainer.className = "pl-2 border-l border-slate-100 ml-2 mt-1 space-y-1";
                items.forEach(p => itemContainer.appendChild(createLessonItem(p)));
                list.appendChild(itemContainer);
            }
        });    }
    function createLessonItem(p) {        const el = document.createElement('div');        el.className = "group relative p-2 rounded-lg hover:bg-slate-50 border border-transparent hover:border-slate-100 cursor-pointer transition-all";                const d = new Date(p.updated);        const dateStr = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });        const pinColor = p.pinned ? 'text-sky-600' : 'text-slate-300 hover:text-slate-500';
        el.innerHTML = `            <div class="flex justify-between items-start">                <div class="w-full pr-16">                    <div class="font-bold text-slate-700 text-sm leading-tight truncate mb-0.5">${p.title}</div>                    <div class="text-[9px] text-slate-400 font-medium font-mono">${dateStr}</div>                </div>                                <div class="absolute right-2 top-2 flex items-center gap-1 item-actions bg-white/80 backdrop-blur rounded-lg pl-1">                    <button class="p-1.5 rounded hover:bg-slate-100 ${pinColor} transition-colors" onclick="togglePin('${p.id}', event)" title="Pin">                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z"/></svg>                    </button>                    <button class="p-1.5 rounded text-slate-400 hover:text-sky-600 hover:bg-sky-50 transition-colors" onclick="duplicateLesson('${p.id}', event)" title="Duplicate">                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>                    </button>                    <button class="p-1.5 rounded text-slate-400 hover:text-sky-600 hover:bg-sky-50 transition-colors" onclick="openExistingEditor('${p.id}'); event.stopPropagation();" title="Edit">                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>                    </button>                    <button class="p-1.5 rounded text-slate-400 hover:text-red-500 hover:bg-red-50 transition-colors" onclick="deleteLessonById('${p.id}', event)" title="Delete">                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>                    </button>                </div>            </div>        `;        el.onclick = () => loadPlan(p);        return el;    }
    function filterLessons(query) {        if(!query) { refreshSidebar(); return; }        DB.getMeta().then(plans => {            const filtered = plans.filter(p => p.title.toLowerCase().includes(query.toLowerCase()) || (p.category||'').toLowerCase().includes(query.toLowerCase()));            renderLessonList(filtered);        });    }
    function loadPlan(p){        if(window.innerWidth < 1024) toggleSidebar(false);        switchView('preview-view');        currentEditingId = p.id;                try {            document.getElementById('preview-title').textContent = p.title || 'Untitled Lesson';            const cat = p.category || 'Uncategorized';            document.getElementById('preview-meta').innerHTML = `<span class="text-[10px] font-bold text-white bg-slate-400 px-2 py-0.5 rounded-full uppercase tracking-wider">${cat}</span>`;                        let content = '';            if (Array.isArray(p.content)) content = p.content.join('');            else if (typeof p.content === 'string') content = p.content;                        const ytRegex = /(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/(?:[^\/\n\s]+\/\S+\/|(?:v|e(?:mbed)?)\/|\S*?[?&]v=)|youtu\.be\/)([a-zA-Z0-9_-]{11})/g;                        content = content.replace(ytRegex, (match, id) => {                return `<div class="video-container"><iframe src="https://www.youtube.com/embed/${id}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>`;            });
            const urlRegex = /((https?:\/\/[^\s<]+))/g;                        content = content.replace(urlRegex, (url) => {                if (url.includes('youtube.com/embed')) return url;                return `<a href="${url}" target="_blank" class="text-sky-600 hover:underline break-all">${url}</a>`;             });
            content = content.replace(/<a href="<a href="/g, '<a href="').replace(/">.*<\/a>"/g, '">');
            document.getElementById('preview-body').innerHTML = content || '<p class="text-slate-400 italic">No content.</p>';        } catch(e) {            console.error(e);        }    }
    async function exportData() {        const data = await DB.exportAll();        const blob = new Blob([JSON.stringify(data, null, 2)], {type: 'application/json'});        const url = URL.createObjectURL(blob);        const a = document.createElement('a');        a.href = url;        a.download = `discipler-backup-${new Date().toISOString().slice(0,10)}.json`;        document.body.appendChild(a);        a.click();        document.body.removeChild(a);    }
    async function importBackup(e) {        const file = e.target.files[0];        if(!file) return;        const reader = new FileReader();        reader.onload = async (e) => {            try {                const json = JSON.parse(e.target.result);                await DB.bulkImport(json);                await renderDash();                await refreshSidebar();                alert('Import successful!');            } catch(err) {                alert('Invalid JSON file.');            }        };        reader.readAsText(file);    }
    function switchView(id){        document.querySelectorAll('.app-view').forEach(v => { v.classList.remove('active'); v.style.display='none'; });        const t = document.getElementById(id);         if(t) { t.style.display='flex'; setTimeout(() => t.classList.add('active'), 10); }    }
    function toggleSidebar(open){        const s = document.getElementById('sidebar'); const b = document.getElementById('sidebar-backdrop');        if(open){ s.classList.remove('-translate-x-full'); b.classList.remove('hidden'); }         else { s.classList.add('-translate-x-full'); b.classList.add('hidden'); }    }
    init();    </script></body></html></template>
<script>    (function() {        const template = document.getElementById('discipler-source');        const iframe = document.getElementById('discipler-frame');        const doc = iframe.contentWindow.document;        doc.open();        doc.write(template.innerHTML);        doc.close();    })();</script>
